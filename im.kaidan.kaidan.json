{
    "id": "im.kaidan.kaidan",
    "rename-icon": "kaidan",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kaidan",
    "separate-locales": false,
    "finish-args": [
        "--device=all",
        "--device=dri",
        "--env=LD_LIBRARY_PATH=/usr/lib/",
        "--filesystem=home",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=wayland",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/lib/pkgconfig",
        "/mkspecs",
        "/share/doc",
        "/share/qlogging-categories6",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "kdsingleapplication",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DKDSingleApplication_QT6=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/KDAB/KDSingleApplication/archive/refs/tags/v1.2.1.tar.gz",
                    "sha256": "e3254ce9dc5ecf6d61ef83264bc61d486a307f0e3c9ed1bb2176f068cdbcbe09",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 370439,
                        "stable-only": true,
                        "url-template": "https://github.com/KDAB/KDSingleApplication/archive/refs/tags/v$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "kquickimageeditor",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/kquickimageeditor/kquickimageeditor-0.6.2.1.tar.xz",
                    "sha256": "6d37a479463dcd16e4746d8b43d4adb05640e8b49056baabc82c865e2e1a4c85",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 229033,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/kquickimageeditor/kquickimageeditor-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "ffmpegthumbs",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.3/src/ffmpegthumbs-26.04.3.tar.xz",
                    "sha256": "a6d7a12a57f24113789203413d40a4355ce4c0aff516384ecd2c548ce42f389b",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/ffmpegthumbs-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "qtkeychain",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/frankosterfeld/qtkeychain/archive/0.17.0.tar.gz",
                    "sha256": "3b85c3929034b0a99da777130c34d99f006fcd3a9d56564159399a33fee0e504",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 381807,
                        "stable-only": true,
                        "url-template": "https://github.com/frankosterfeld/qtkeychain/archive/$version.tar.gz"
                    }
                }
            ],
            "config-opts": [
                "-DCMAKE_INSTALL_LIBDIR=/app/lib",
                "-DLIB_INSTALL_DIR=/app/lib",
                "-DBUILD_TRANSLATIONS=NO",
                "-DBUILD_WITH_QT6=ON"
            ]
        },
        {
            "name": "qxmpp",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DBUILD_EXAMPLES=OFF",
                "-DBUILD_OMEMO=ON",
                "-DWITH_GSTREAMER=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/unstable/qxmpp/qxmpp-1.16.3.tar.xz",
                    "sha256": "005f460a9499467c4e13c35d34df4d274204d4edd673798fab1c39cb73894ab8",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 4149,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/unstable/qxmpp/qxmpp-$version.tar.xz"
                    }
                }
            ],
            "modules": [
                {
                    "name": "libomemo-c",
                    "buildsystem": "cmake-ninja",
                    "config-opts": [
                        "-DBUILD_SHARED_LIBS=ON",
                        "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/dino/libomemo-c/archive/refs/tags/v0.5.1.tar.gz",
                            "sha256": "d1b65dbf7bccc67523abfd5e429707f540b2532932d128b2982f0246be2b22a0",
                            "x-checker-data": {
                                "type": "anitya",
                                "project-id": 359676,
                                "stable-only": true,
                                "url-template": "https://github.com/dino/libomemo-c/archive/refs/tags/v$version.tar.gz"
                            }
                        }
                    ],
                    "modules": [
                        {
                            "name": "libprotobuf-c",
                            "buildsystem": "autotools",
                            "config-opts": [
                                "--disable-protoc"
                            ],
                            "sources": [
                                {
                                    "type": "archive",
                                    "url": "https://github.com/protobuf-c/protobuf-c/archive/refs/tags/v1.5.2.tar.gz",
                                    "sha256": "cea46eeaa19c52924938b582c5d128a6ed3b6fb5b3f4677476a1781cc06e03f3",
                                    "x-checker-data": {
                                        "type": "anitya",
                                        "project-id": 3716,
                                        "stable-only": true,
                                        "url-template": "https://github.com/protobuf-c/protobuf-c/archive/refs/tags/v$version.tar.gz"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "name": "qml6glsink",
            "buildsystem": "meson",
            "no-make-install": true,
            "post-install": [
                "install -Dt /app/lib/gstreamer-1.0/ ext/qt6/libgstqml6.so"
            ],
            "config-opts": [
                "-Dqt6=enabled",
                "-Dqt-egl=enabled",
                "-Dqt-wayland=enabled",
                "-Dqt-x11=enabled"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gstreamer.freedesktop.org/src/gst-plugins-good/gst-plugins-good-1.26.10.tar.xz",
                    "sha256": "7beacb5daba3c6751ebc1c85017d9b1d6de64e24798125932c73c8b1dbeb3bc9",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 21852,
                        "stable-only": true,
                        "versions": {
                            "==": "1.26.10"
                        },
                        "url-template": "https://gstreamer.freedesktop.org/src/gst-plugins-good/gst-plugins-good-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "kaidan",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/unstable/kaidan/0.16.0/kaidan-0.16.0.tar.xz",
                    "sha256": "b38a64c7b7524a32dffe08eeda034f76d3597a84d8f7afd25c658dab43fb074d",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 361480,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/unstable/kaidan/$version/kaidan-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
